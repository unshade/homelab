# Talos generated secrets - plaintext versions never get committed.
# Only the .sops.yaml-encrypted copies (talos/_out/*.enc.yaml) are versioned.
talos/_out/controlplane.yaml
talos/_out/controlplane-cp2.yaml
talos/_out/worker.yaml
talos/_out/talosconfig
talos/_out/kubeconfig

secrets

# Decrypted copies of *-sops.yaml secrets (see scripts/decrypt-sops-secrets.sh) -
# convenience-only, regenerated locally, never committed.
*-sops.dec.yaml
